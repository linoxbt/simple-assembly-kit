  "accounts": [
    {
      "name": "Vault",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "owner", "type": "publicKey"},
          {"name": "collateralMint", "type": "publicKey"},
          {"name": "collateralAmount", "type": "u64"},
          {"name": "xusdMinted", "type": "u64"},
          {"name": "lastUpdated", "type": "i64"},
          {"name": "isLiquidated", "type": "bool"},
          {"name": "bump", "type": "u8"}
        ]
      }
    },
    {
      "name": "PriceAccount",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "asset", "type": {"array": ["u8", 8]}},
          {"name": "price", "type": "u64"},
          {"name": "publishedAt", "type": "i64"},
          {"name": "authority", "type": "publicKey"},
          {"name": "fromSix", "type": "bool"},
          {"name": "bump", "type": "u8"}
        ]
      }
    },
    {
      "name": "AllowList",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "admin", "type": "publicKey"},
          {"name": "members", "type": {"vec": "publicKey"}},
          {"name": "bump", "type": "u8"}
        ]
      }
    },
    {
      "name": "TravelRuleRecord",
      "type": {
        "kind": "struct",
        "fields": [
          {"name": "transferId", "type": {"array": ["u8", 32]}},
          {"name": "originatorName", "type": {"array": ["u8", 64]}},
          {"name": "originatorVasp", "type": {"array": ["u8", 64]}},
          {"name": "beneficiaryName", "type": {"array": ["u8", 64]}},
          {"name": "beneficiaryVasp", "type": {"array": ["u8", 64]}},
          {"name": "amount", "type": "u64"},
          {"name": "from", "type": "publicKey"},
          {"name": "to", "type": "publicKey"},
          {"name": "timestamp", "type": "i64"},
          {"name": "bump", "type": "u8"}
        ]
      }
    }
  ],
  "events": [
    {
      "name": "KytEvent",
      "fields": [
        {"name": "from", "type": "publicKey", "index": false},
        {"name": "action", "type": "string", "index": false},
        {"name": "amount", "type": "u64", "index": false},
        {"name": "timestamp", "type": "i64", "index": false},
        {"name": "flagged", "type": "bool", "index": false}
      ]
    }
  ],
  "errors": [
    {"code": 6000, "name": "KycNotVerified", "msg": "Wallet not KYC verified."},
    {"code": 6001, "name": "StalePrice", "msg": "Price feed is stale (> 60 seconds old)."},
    {"code": 6002, "name": "BadPrice", "msg": "Price is zero."},
    {"code": 6003, "name": "NotEnoughCollateral", "msg": "Not enough collateral. Minimum 150% ratio required."},
    {"code": 6004, "name": "VaultHealthy", "msg": "Vault is healthy. Cannot liquidate."},
    {"code": 6005, "name": "VaultDead", "msg": "Vault already liquidated."},
    {"code": 6006, "name": "TooMuch", "msg": "Amount exceeds debt."},
    {"code": 6007, "name": "ZeroAmount", "msg": "Amount must be greater than zero."},
    {"code": 6008, "name": "TravelRuleIncomplete", "msg": "Fill all 4 VASP fields for transfers above $3,000."},
    {"code": 6009, "name": "NotAdmin", "msg": "Not the admin."},
    {"code": 6010, "name": "AlreadyOnList", "msg": "Wallet already on the allowlist."},
    {"code": 6011, "name": "ListFull", "msg": "Allowlist is full."},
    {"code": 6012, "name": "Overflow", "msg": "Math overflow."}
